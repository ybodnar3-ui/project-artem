# Offer Machine — environment variables
# Copy to .env.local and fill in. .env.local is gitignored — never commit real secrets.

# Anthropic API key (both Claude calls)
ANTHROPIC_API_KEY=

# Neon Postgres connection string (HTTP driver)
DATABASE_URL=

# Random secret used to hash IPs for rate limiting: sha256(ip + IP_SALT)
IP_SALT=

# Public base URL for OG tags and copy-link (e.g. https://offer-machine.vercel.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
